generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PhoneSegment {
  entry
  budget
  entry_mid
  midrange
  upper_mid
  flagship
  ultra_flagship
}

enum EnrichmentStatus {
  pending
  queued
  processing
  completed
  fallback
  failed
}

enum SourceKind {
  gsmarena
  kimovil
  nanoreview
}

model Phone {
  id                   String            @id @default(cuid())
  slug                 String            @unique
  brand                String
  model                String
  segment              PhoneSegment
  price                Int
  performanceScore     Float?
  cameraScore          Float?
  batteryScore         Float?
  valueScore           Float?
  finalScore           Float?
  display              String?
  chipset              String?
  gpu                  String?
  ram                  Int?
  storage              Int?
  cameraMain           Int?
  cameraUltrawide      Int?
  battery              Int?
  charging             Int?
  os                   String?
  releaseYear          Int?
  releaseDate          DateTime?
  benchmarkScore       Int?
  aiSummary            String?
  enrichmentStatus     EnrichmentStatus  @default(pending)
  enrichmentConfidence Float?
  preferredSource      SourceKind?
  lastEnrichedAt       DateTime?
  rawSeed              Json
  enrichmentPayload    Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  sources              PhoneSource[]
  jobs                 EnrichmentJob[]
  favorites            Favorite[]
  leftComparisons      ComparisonSnapshot[] @relation("ComparisonLeftPhone")
  rightComparisons     ComparisonSnapshot[] @relation("ComparisonRightPhone")

  @@index([segment, price])
  @@index([brand, model])
  @@index([finalScore])
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  favorites           Favorite[]
  comparisonSnapshots ComparisonSnapshot[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  phoneId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     Phone    @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@unique([userId, phoneId])
  @@index([userId, createdAt])
  @@index([phoneId])
}

model ComparisonSnapshot {
  id           String   @id @default(cuid())
  userId       String
  leftPhoneId  String
  rightPhoneId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leftPhone    Phone    @relation("ComparisonLeftPhone", fields: [leftPhoneId], references: [id], onDelete: Cascade)
  rightPhone   Phone    @relation("ComparisonRightPhone", fields: [rightPhoneId], references: [id], onDelete: Cascade)

  @@unique([userId, leftPhoneId, rightPhoneId])
  @@index([userId, updatedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PhoneSource {
  id            String      @id @default(cuid())
  phoneId       String
  sourceKind    SourceKind
  sourceUrl     String
  cacheKey      String      @unique
  rawMarkdown   String?
  rawExtraction Json?
  fetchedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  phone         Phone       @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@index([phoneId, sourceKind])
}

model EnrichmentJob {
  id         String           @id @default(cuid())
  phoneId     String
  status     EnrichmentStatus @default(queued)
  provider   String?
  sourceKind SourceKind?
  attempts   Int              @default(0)
  error      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?
  phone      Phone            @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}
